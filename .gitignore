# .gitignore — TaskFlow API

# Laravel
/vendor/
/node_modules/
.env
.env.backup
.env.production
.phpunit.result.cache
Homestead.json
Homestead.yaml
auth.json
/.fleet
/.idea
/.vscode
*.code-workspace

# Storage (user uploads, logs) — never commit
/storage/*.key
/storage/app/attachments/*
!/storage/app/attachments/.gitkeep
/storage/logs/*.log

# Docker
docker-compose.override.yml

# Coverage reports
/coverage/
coverage.xml
.phpunit.cache/

# OS files
.DS_Store
Thumbs.db
